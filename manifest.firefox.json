{
  "manifest_version": 3,
  "name": "Unbar",
  "version": "1.0.0",
  "description": "Unbar your videos — crop, zoom, stretch or auto-fit any video to remove black bars. Ctrl+Scroll over a video to switch modes.",
  "browser_specific_settings": {
    "gecko": {
      "id": "unbar@addon",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Unbar"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["modes.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
