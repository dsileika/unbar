{
  "manifest_version": 3,
  "name": "Unbar",
  "version": "1.0.0",
  "description": "Unbar your videos — crop, zoom, stretch or auto-fit any video to remove black bars. Ctrl+Scroll over a video to switch modes.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Unbar"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
